rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    function isAdmin() {
      return request.auth != null && 
             get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
    }
    
    match /users/{userId} {
      allow read: if request.auth != null;
      allow write: if request.auth != null && request.auth.uid == userId;
      allow update: if isAdmin();
      
      // User subcollections
      match /question_sets/{setId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /results/{resultId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /vocab/{vocabId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /wishlist/{wishlistId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
      
      match /attempts/{attemptId} {
        allow read, write: if request.auth != null && request.auth.uid == userId;
      }
    }
    
    match /question_sets/{setId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.createdBy || isAdmin());
    }
    
    match /questions/{questionId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && (request.auth.uid == resource.data.createdBy || isAdmin());
    }
    
    match /attempts/{attemptId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow create, update: if request.auth != null;
    }
    
    match /posts/{postId} {
      allow read: if true;
      allow create: if request.auth != null;
      allow update: if request.auth != null;
      allow delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
    }
    
    match /tryouts/{tryoutId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
    
    match /tryout_attempts/{attemptId} {
      allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
      allow create: if request.auth != null;
      allow update: if isAdmin();
    }
    
    match /admin_logs/{logId} {
      allow read, write: if isAdmin();
    }
    
    match /vocab/{vocabId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
      allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    match /wishlist/{wishlistId} {
      allow read: if request.auth != null && request.auth.uid == resource.data.userId;
      allow create: if request.auth != null;
      allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
    }
    
    match /api_keys/{keyId} {
      allow read: if request.auth != null;
      allow write: if isAdmin();
    }
  }
}
