rules_version = '2';
service cloud.firestore {
  function isAdmin() {
    return request.auth != null && 
           get(/databases/$(database)/documents/users/$(request.auth.uid)).data.role == "admin";
  }
  
  // Users - own data only
  match /users/{userId} {
    allow read: if request.auth != null;
    allow write: if request.auth != null && request.auth.uid == userId;
    allow update: if isAdmin();
    
    // User subcollections
    match /question_sets/{setId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /results/{resultId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /vocab/{vocabId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /wishlist/{wishlistId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
    match /attempts/{attemptId} {
      allow read, write: if request.auth != null && request.auth.uid == userId;
    }
  }
  
  // Question Sets - public read, owner write
  match /question_sets/{setId} {
    allow read: if true;
    allow create: if request.auth != null;
    allow update, delete: if request.auth != null && (request.auth.uid == resource.data.createdBy || isAdmin());
  }
  
  // Questions - public read, owner write
  match /questions/{questionId} {
    allow read: if true;
    allow create: if request.auth != null;
    allow update, delete: if request.auth != null && (request.auth.uid == resource.data.createdBy || isAdmin());
  }
  
  // Attempts - owner only
  match /attempts/{attemptId} {
    allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
    allow create, update: if request.auth != null;
  }
  
  // Posts - community
  match /posts/{postId} {
    allow read: if true;
    allow create, update: if request.auth != null;
    allow delete: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
  }
  
  // Tryouts - admin only write
  match /tryouts/{tryoutId} {
    allow read: if request.auth != null;
    allow write: if isAdmin();
  }
  
  // Tryout Attempts - owner only
  match /tryout_attempts/{attemptId} {
    allow read: if request.auth != null && (request.auth.uid == resource.data.userId || isAdmin());
    allow create: if request.auth != null;
    allow update: if isAdmin();
  }
  
  // Admin Logs - admin only
  match /admin_logs/{logId} {
    allow read, write: if isAdmin();
  }
  
  // Vocab - owner only
  match /vocab/{vocabId} {
    allow read: if request.auth != null && request.auth.uid == resource.data.userId;
    allow create: if request.auth != null;
    allow update, delete: if request.auth != null && request.auth.uid == resource.data.userId;
  }
  
  // Wishlist - owner only
  match /wishlist/{wishlistId} {
    allow read: if request.auth != null && request.auth.uid == resource.data.userId;
    allow create: if request.auth != null;
    allow delete: if request.auth != null && request.auth.uid == resource.data.userId;
  }
  
  // User Progress - owner only
  match /user_progress/{documentId} {
    allow read, create, update: if request.auth != null && request.auth.uid == documentId;
    allow delete: if false;
  }
  
  // User Metrics - owner only
  match /user_metrics/{documentId} {
    allow read, create, update: if request.auth != null && request.auth.uid == documentId;
    allow delete: if false;
  }
  
  // Learning Stats - owner only
  match /learning_stats/{userId}/topics/{topicId} {
    allow read, create, update, delete: if request.auth != null && request.auth.uid == userId;
  }
  
  // Question Completions - immutable
  match /question_completions/{documentId} {
    allow read: if request.auth != null && 
                   (resource.data.userId == request.auth.uid || 
                    (request.auth.uid == request.resource.data.userId));
    allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    allow update, delete: if false;
  }
  
  // Question Answers - immutable
  match /question_answers/{documentId} {
    allow read: if request.auth != null &&
                 (resource.data.userId == request.auth.uid ||
                  (request.auth.uid == request.resource.data.userId));
    allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    allow update, delete: if false;
  }
  
  // Exam Sessions - immutable records
  match /exam_sessions/{sessionId} {
    allow read: if request.auth != null && 
                   (resource.data.userId == request.auth.uid || isAdmin());
    allow create: if request.auth != null && request.resource.data.userId == request.auth.uid;
    allow update, delete: if false;
  }
  
  // API Keys - admin only
  match /api_keys/{keyId} {
    allow read: if request.auth != null;
    allow write: if isAdmin();
  }
}
