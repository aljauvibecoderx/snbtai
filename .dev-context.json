{
  "project": {
    "name": "SNBT AI",
    "type": "React Web Application",
    "description": "AI-Powered SNBT Learning Platform"
  },
  "commands": {
    "publish": {
      "action": "deploy",
      "steps": [
        "git add .",
        "git commit -m '[descriptive message based on changes]'",
        "git push origin main"
      ],
      "note": "Commit message must describe the actual changes made"
    },
    "bikin branch": {
      "action": "create_branch",
      "command": "git checkout -b [branch_name]"
    },
    "kembali ke branch": {
      "action": "switch_branch",
      "command": "git checkout [branch_name]"
    },
    "git remote add origin": {
      "action": "setup_and_push",
      "steps": [
        "git remote add origin [url]",
        "git branch -M main",
        "git push -u origin main"
      ]
    }
  },
  "git": {
    "remote": "origin",
    "main_branch": "main",
    "current_branch": "main"
  },
  "rules": [
    "Minimal code implementation",
    "No verbose solutions",
    "Direct problem solving",
    "Commit messages must describe actual changes made, not generic messages"
  ]
}
